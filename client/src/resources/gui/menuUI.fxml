         <Button fx:id="DefaultButton1" maxHeight="-Infinity" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDefaultButton" prefHeight="30.0" style="-fx-background-color: #ae0000;" text="Default" textFill="WHITE">
