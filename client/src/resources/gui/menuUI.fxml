         <Text fill="#ae0000" strokeType="OUTSIDE" strokeWidth="0.0" text="Connessione" textAlignment="CENTER" underline="true" wrappingWidth="269.0">
            <font>
               <Font name="Consolas Bold" size="36.0" />
            </font>
            <VBox.margin>
               <Insets />
            </VBox.margin>
         </Text>
         <Text fill="#ae0000" strokeType="OUTSIDE" strokeWidth="0.0" text="Indirizzo IP" textAlignment="CENTER" wrappingWidth="150.0">
            <font>
               <Font name="Consolas Bold" size="18.0" />
            </font>
            <VBox.margin>
               <Insets top="5.0" />
            </VBox.margin>
         </Text>
         <TextField fx:id="IpTextField1" alignment="CENTER_RIGHT" maxWidth="1.7976931348623157E308" nodeOrientation="RIGHT_TO_LEFT" prefHeight="26.0" prefWidth="321.0" promptText="127.0.0.1" VBox.vgrow="ALWAYS" />
         <Text fill="#ae0000" strokeType="OUTSIDE" strokeWidth="0.0" text="Numero Porta" textAlignment="CENTER" wrappingWidth="150.0">
